APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=3000
APP_URL=http://127.0.0.1:3000
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
META_DEFAULT_TITLE=Sentinel
META_DESCRIPTION=Autonomous brand threat intelligence.
META_LOCALE=en

# Mongo — local default; override with an Atlas URI if you have one.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=win_win

# Session cookie name (don't change after users have logged in).
SESSION_COOKIE=ww_session

# Inference
INFERENCE_PROVIDER=gemini
INFERENCE_MODEL=gemini-2.5-flash
INFERENCE_SYSTEM_PROMPT=
INFERENCE_MAX_OUTPUT_TOKENS=8192
GEMINI_API_KEY=
VULTR_INFERENCE_API_KEY=

# Bright Data competitor overview pipeline
# Required for company overview runs
BRIGHTDATA_API_KEY=fa071540-5f74-423c-8bfb-524a4e1b75ce
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker1

# Optional runtime features
# Browser API fallback auth, format: username:password
BRIGHTDATA_SCRAPING_BROWSER_AUTH=
BRIGHTDATA_PROXY_URL=

# Optional dataset scrapers. If omitted, the pipeline will fall back to
# SERP discovery + Web Unlocker page extraction for those sources.
BRIGHTDATA_TRUSTPILOT_DATASET_ID=
BRIGHTDATA_G2_DATASET_ID=
BRIGHTDATA_CAPTERRA_DATASET_ID=

# Optional override. Defaults to Bright Data's documented LinkedIn company dataset.
BRIGHTDATA_LINKEDIN_COMPANY_DATASET_ID=

# Cognee knowledge-graph (optional — supercharges chat with structured company intelligence)
# Register or log in at http://your-cognee-server/api/v1/auth/register
COGNEE_URL=http://64.177.116.163:8000
COGNEE_EMAIL=
COGNEE_PASSWORD=

# Autonomous monitoring ("Watchtower")
# Background patrol that re-scans every tracked company on a schedule.
# Defaults: enabled, 6h cadence, first patrol 90s after boot.
WATCHTOWER_ENABLED=true
WATCHTOWER_INTERVAL_SECS=21600
WATCHTOWER_FIRST_DELAY_SECS=90

# Triggerware enterprise monitor layer
TRIGGERWARE_API_URL=https://api.triggerware.com
TRIGGERWARE_API_KEY=
TRIGGERWARE_POLL_INTERVAL_SECS=900

# Alert delivery
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Speechmatics realtime voice (Voice Assistant tab)
# Server-side only — the browser never sees this key.
SPEECHMATICS_API_KEY=
# Optional overrides (sane defaults baked in):
# SPEECHMATICS_RT_URL=wss://eu2.rt.speechmatics.com/v2
# SPEECHMATICS_MGMT_URL=https://mp.speechmatics.com/v1
# SPEECHMATICS_TTS_URL=https://preview.tts.speechmatics.com
# SPEECHMATICS_TTS_VOICE=megan
# Spoken Web scout — Speechmatics batch transcription of earnings calls / YouTube / podcasts
# SPEECHMATICS_BATCH_URL=https://asr.api.speechmatics.com/v2
